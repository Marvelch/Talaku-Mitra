# Database configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=Moronge90
DB_NAME=talaku
DB_SSLMODE=disable

# JWT Secrets (wajib diisi, gunakan string yang panjang dan acak)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Server
SERVER_PORT=8080

# SMTP (untuk email lupa password). Jika SMTP_HOST kosong, kode reset akan dicatat ke log server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@talaku.app
PASSWORD_RESET_CODE_EXPIRY=15m

# WhatsApp OTP gateway (untuk verifikasi nomor telepon saat register).
# Jika WA_GATEWAY_URL kosong, kode OTP akan dicatat ke log server.
WA_GATEWAY_URL=
ZENZIVA_USERKEY=
ZENZIVA_PASSKEY=
APP_BRAND_NAME=Talaku Mitra
